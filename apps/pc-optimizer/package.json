{
  "name": "@avs/pc-optimizer",
  "version": "0.1.0",
  "private": true,
  "description": "AVS PC Optimizer — Windows performance, cleanup, and privacy utility.",
  "main": "dist-electron/main/index.js",
  "author": "AVS Software",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env AVS_ENV=development electron .",
    "build": "tsc -p tsconfig.json --noEmit && vite build && cd electron && tsc",
    "package": "yarn build && electron-builder --win --x64",
    "package:dir": "yarn build && electron-builder --dir",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint \"{src,electron}/**/*.{ts,tsx}\" --max-warnings=0"
  },
  "dependencies": {
    "@avs/analytics": "0.1.0",
    "@avs/core": "0.1.0",
    "@avs/licensing": "0.1.0",
    "@avs/shared": "0.1.0",
    "@avs/ui": "0.1.0",
    "@avs/updater": "0.1.0",
    "@heroicons/react": "^2.1.3",
    "clsx": "^2.1.0",
    "electron-log": "^5.1.2",
    "electron-updater": "^6.1.8",
    "i18next": "^23.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.22.3",
    "react-window": "^1.8.10",
    "recharts": "^2.12.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron": "30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.avs.pcoptimizer",
    "productName": "AVS PC Optimizer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.avs.example.com/pc-optimizer/${channel}"
      }
    ]
  }
}
